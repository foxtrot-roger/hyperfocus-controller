<Window x:Class="RFE.FocusTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RFE.FocusTimer"
        xmlns:properties="clr-namespace:RFE.FocusTimer.Properties"
        Title="Focus Timer" 
        Width="380" 
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="#F3F3F3"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <Style x:Key="ModernText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}"/>

        <Style x:Key="ControlBtn" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Width" Value="100"/>

        </Style>

        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <local:LessThanConverter x:Key="LessThanConverter"/>
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="Background" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                    <Setter Property="Foreground" Value="#888888"/>
                    <Setter Property="Background" Value="#CCCCCC"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, 
                                     Path=Value, 
                                     Converter={StaticResource LessThanConverter}, 
                                     ConverterParameter=30}" 
                             Value="True">
                    <Setter Property="Foreground" Value="#FF8C00"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, 
                                  Path=Value, 
                                  Converter={StaticResource LessThanConverter}, 
                                  ConverterParameter=10}" 
                          Value="True">
                    <Setter Property="Foreground" Value="#FF0033"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid x:Name="StartTimerScreen" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Style="{StaticResource ModernText}" Text="Task" FontSize="11" Opacity="0.6" Margin="0,0,0,4"/>
                <TextBox x:Name="MessageInput" FontSize="14" Height="36" HorizontalContentAlignment="Left" Padding="10,0"
                 Text="{Binding Source={x:Static properties:Settings.Default}, Path=LastMessage, Mode=TwoWay}"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource ModernText}" Text="Duration" FontSize="11" Opacity="0.6" Margin="0,0,0,4"/>
                    <TextBox x:Name="TimeInput" FontSize="20" Height="40" FontWeight="SemiBold"
                     Text="{Binding Source={x:Static properties:Settings.Default}, Path=LastDuration, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource ModernText}" Text="Unit" FontSize="11" Opacity="0.6" Margin="0,0,0,4"/>
                    <ComboBox x:Name="UnitSelector" SelectedIndex="{Binding Source={x:Static properties:Settings.Default}, Path=LastUnitIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Hours"/>
                        <ComboBoxItem Content="Minutes"/>
                        <ComboBoxItem Content="Seconds"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource ModernText}" Text="Reminders (comma separated)" FontSize="11" Opacity="0.6" Margin="0,0,0,4"/>
                    <TextBox x:Name="WarningInput" FontSize="16" Height="40"
                     Text="{Binding Source={x:Static properties:Settings.Default}, Path=LastReminders, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource ModernText}" Text="Mode" FontSize="11" Opacity="0.6" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ReminderModeSelector" 
                      SelectedIndex="{Binding Source={x:Static properties:Settings.Default}, Path=ReminderModeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Absolute (Units)"/>
                        <ComboBoxItem Content="Percentage (%)"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="4">
                <Button x:Name="StartBtn" Content="START" Height="45" FontSize="14" Click="StartBtn_Click"/>
            </Grid>
        </Grid>

        <StackPanel x:Name="WarningScreen" Visibility="Visible">
            <Viewbox>
                <TextBlock x:Name="RemainingTime" 
                       Text="00:00"
                       FontFamily="Consolas" 
                       Foreground="#0078D4" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
            </Viewbox>

            <TextBlock Style="{StaticResource ModernText}" Text="{Binding Text, ElementName=MessageInput}"/>

            <Border Height="10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ProgressBar Grid.Column="2" x:Name="TimerProgressBar" 
                         Grid.Row="1" 
                         Minimum="0" 
                         Maximum="100"
                         Value="50"
                         Style="{StaticResource ModernProgressBar}"/>

                <Border x:Name="PulseBorder" Background="#107C10">
                    <Border x:Name="PulseCenter" Margin="6">
                        <Border.Effect>
                            <BlurEffect Radius="2"/>
                        </Border.Effect>
                    </Border>
                </Border>
            </Grid>

            <Border Height="10"/>

            <Grid>
                <Button x:Name="PauseBtn" HorizontalAlignment="Left" Content="PAUSE" Style="{StaticResource ControlBtn}" Background="#666666" Click="PauseBtn_Click"/>
                <Button x:Name="StopBtn" HorizontalAlignment="Right" Content="STOP" Style="{StaticResource ControlBtn}" Background="#D13438" Click="ResetBtn_Click"/>
            </Grid>
        </StackPanel>

        <Grid x:Name="TimeIsUpScreen" Visibility="Collapsed">

            <StackPanel VerticalAlignment="Center">
                <Viewbox Grid.Row="0" Margin="10,0" MaxWidth="400">
                    <TextBlock x:Name="DisplayArea" Text="Time's up!" Foreground="#E81123" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Viewbox>

                <Border Height="10"/>

                <TextBlock Style="{StaticResource ModernText}" HorizontalAlignment="Center" Text="{Binding Text, ElementName=MessageInput}"/>

                <Border Height="10"/>

                <Button x:Name="ResetBtn" Grid.Row="1" MaxWidth="100" Content="New Timer" Click="ResetBtn_Click"/>
            </StackPanel>

        </Grid>
    </Grid>
</Window>